# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL="mysql://user:password@localhost:3306/tf_api"

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# OpenAPI debug payload (never enable in production)
ENABLE_DEBUG_PAYLOAD=false

# --- Vendor credentials (env-only, NEVER in DB or code) ---

# Mock provider (no credentials needed, always enabled in non-prod)
MOCK_PROVIDER_ENABLED=true

# ICICI Lombard — disabled until UAT creds + AES spec + IP whitelisting land.
# Base URL: UAT https://ilesbapigee.insurancearticlez.com  |  PROD https://janus.icicilombard.com
ICICI_ENABLED=false
ICICI_BASE_URL=https://ilesbapigee.insurancearticlez.com
ICICI_LOGIN=
ICICI_PASSWORD=
# Base64 AES key shared by ICICI; exact mode TBC with vendor.
ICICI_AES_KEY=
ICICI_AES_MODE=aes-256-ecb
