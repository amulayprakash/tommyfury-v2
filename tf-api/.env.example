# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL="mysql://user:password@localhost:3306/tf_api"

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# OpenAPI debug payload (never enable in production)
ENABLE_DEBUG_PAYLOAD=false

# --- Vendor credentials (env-only, NEVER in DB or code) ---

# Mock provider (no credentials needed, always enabled in non-prod)
MOCK_PROVIDER_ENABLED=true

# ICICI Lombard — disabled until UAT creds + AES spec + IP whitelisting land.
# Base URL: UAT https://ilesbapigee.insurancearticlez.com  |  PROD https://janus.icicilombard.com
ICICI_ENABLED=false
ICICI_BASE_URL=https://ilesbapigee.insurancearticlez.com
ICICI_LOGIN=
ICICI_PASSWORD=
# Base64 AES key shared by ICICI; exact mode TBC with vendor.
ICICI_AES_KEY=
ICICI_AES_MODE=aes-256-ecb

# Future Generali (TCS Motor API) — SOAP/XML motor + JSON CKYC/renewal.
# UAT gateway https://uat-internal-apigw.generalicentralinsurance.com:8243
# Token URL   https://uat-internal-apim.generalicentralinsurance.com:9443/oauth2/token
# Live UAT may require IP whitelisting; falls back to fixtures in tests.
FG_ENABLED=false
FG_BASE_URL=https://uat-internal-apigw.generalicentralinsurance.com:8243
FG_TOKEN_URL=https://uat-internal-apim.generalicentralinsurance.com:9443/oauth2/token
# Base64 of "client_id:client_secret" for the Authorization: Basic header.
FG_CLIENT_BASIC=
FG_USERNAME=
FG_PASSWORD=
FG_VENDOR_CODE=Webagg
FG_AGENT_CODE=60001464
FG_BRANCH_CODE=10

# FG CKYC (GCKYC/3.0.0) — separate WSO2 product (own client + static Token header).
FG_CKYC_BASE_URL=https://uat-internal-apigw.generalicentralinsurance.com:8243/GCKYC/3.0.0
# FG_CKYC_TOKEN_URL=    # defaults to FG_TOKEN_URL when blank
FG_CKYC_CLIENT_BASIC=
FG_CKYC_SUBSCRIPTION_TOKEN=

# FG Motor Renewal (motorRenewal/1.0.0) — JSON product (legacy futuregenerali.in host).
FG_RENEWAL_BASE_URL=https://uat-internal-apigw.futuregenerali.in:8243/motorRenewal/1.0.0/TCS-Renewal/API/MotorRenewal
# FG_RENEWAL_TOKEN_URL=
FG_RENEWAL_CLIENT_BASIC=

# FG Web-Aggregator payment gateway (checksum-signed form POST to WebAggPayNew.aspx).
FG_PAYMENT_URL=https://fgnluat.fggeneral.in/Ecom_UAT/WEBAPPLN/UI/Common/WebAggPayNew.aspx
FG_PAYMENT_OPTION=3
# Absolute, publicly reachable URL FG redirects to after payment (our callback),
# e.g. https://api.example.com/api/v1/fg/payment/callback
FG_PAYMENT_RESPONSE_URL=
FG_PAYMENT_CHECKSUM_SECRET=
# Absolute web URLs the callback 302-redirects the browser to (defaults to the
# first ALLOWED_ORIGINS entry + /insurance-payment-success | /insurance-payment-failed).
FG_PAYMENT_SUCCESS_URL=
FG_PAYMENT_FAILURE_URL=

# LiveChek break-in / inspection (third-party REST).
LIVECHEK_BASE_URL=https://newapi.test.livechek.com/api
LIVECHEK_APP_KEY=
LIVECHEK_COMPANY_ID=
LIVECHEK_APP_ID=
