generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Providers ──────────────────────────────────────────────────────────────

model Provider {
  id           Int      @id @default(autoincrement())
  slug         String   @unique @db.VarChar(64)
  displayName  String   @db.VarChar(255)
  isActive     Boolean  @default(true)
  capabilities Json     // string[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  quotes       Quote[]

  @@map("providers")
}

// ─── Quotes ─────────────────────────────────────────────────────────────────

model Quote {
  id              Int      @id @default(autoincrement())
  requestId       String   @unique @db.VarChar(64)
  providerSlug    String   @db.VarChar(64)
  provider        Provider @relation(fields: [providerSlug], references: [slug])
  vehicleCategory String   @db.VarChar(32)
  status          String   @db.VarChar(32) @default("pending")

  // Quote identity
  quoteNo                String?  @db.VarChar(128)
  providerTransactionId  String?  @db.VarChar(128)
  policyType             String   @db.VarChar(32)

  // Lifecycle (populated by proposal / KYC / status)
  kycId           String?  @db.VarChar(128)
  policyNumber    String?  @db.VarChar(128)
  policyStatus    String?  @db.VarChar(32)
  paymentLink     String?  @db.VarChar(512)

  // Issuance binding (FG: ClientID + QuotationNo → real PolicyNo + ApplicationNo)
  clientId        String?  @db.VarChar(64)
  applicationNo   String?  @db.VarChar(128)
  receiptNo       String?  @db.VarChar(128)
  // Payment receipt captured on the gateway callback (drives issuance)
  paymentTranKey  String?  @db.VarChar(128)
  paymentRefNo    String?  @db.VarChar(128)
  pgType          String?  @db.VarChar(32)

  // Policy holder (populated on full-quote)
  holderName      String?  @db.VarChar(255)
  holderEmail     String?  @db.VarChar(255)
  holderMobile    String?  @db.VarChar(20)

  // Vehicle
  makeModel       String?  @db.VarChar(255)
  registrationNo  String?  @db.VarChar(32)
  engineNumber    String?  @db.VarChar(64)
  chassisNumber   String?  @db.VarChar(64)

  // Premium (stored as integers in paise to avoid float rounding)
  idvValue        Int?
  netPremium      Int?
  grossPremium    Int?

  // JSON blobs for full audit
  contractDetails Json?
  addonPremiums   Json?
  discounts       Json?
  rawRequest      Json?
  rawFullQuote    Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([providerSlug])
  @@index([status])
  @@index([createdAt])
  @@index([providerTransactionId])
  @@map("quotes")
}

// ─── Health quotes (separate line of business from motor `quotes`) ────────────

model HealthQuote {
  id           Int      @id @default(autoincrement())
  requestId    String   @unique @db.VarChar(64)
  providerSlug String   @db.VarChar(64)
  product      String   @db.VarChar(32)
  line         String   @db.VarChar(16) // indemnity | pa
  status       String   @db.VarChar(32) @default("pending")

  // Quote identity
  quoteNo               String? @db.VarChar(128)
  providerTransactionId String? @db.VarChar(128)

  // Plan
  sumInsured      Int?
  policyTermYears Int     @default(1)
  members         Json?   // per-member breakdown

  // Lifecycle
  policyNumber String? @db.VarChar(128)
  policyStatus String? @db.VarChar(32)
  clientId     String? @db.VarChar(64)
  applicationNo String? @db.VarChar(128)
  receiptNo    String? @db.VarChar(128)
  paymentTranKey String? @db.VarChar(128)
  paymentRefNo   String? @db.VarChar(128)
  pgType         String? @db.VarChar(32)

  // Policy holder
  holderName   String? @db.VarChar(255)
  holderEmail  String? @db.VarChar(255)
  holderMobile String? @db.VarChar(20)

  // Premium (stored as integers in paise to avoid float rounding)
  basePremium  Int?
  netPremium   Int?
  grossPremium Int?

  // JSON blobs for full audit
  contractDetails Json?
  rawRequest      Json?
  rawFullQuote    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerSlug])
  @@index([product])
  @@index([status])
  @@index([providerTransactionId])
  @@map("health_quotes")
}

// ─── Health masters (FG is the master source; FG codes stored on the rows) ─────

model HealthProductMaster {
  id             Int     @id @default(autoincrement())
  code           String  @unique @db.VarChar(32) // canonical product, e.g. healthAbsolute
  label          String  @db.VarChar(255)
  line           String  @db.VarChar(16) // indemnity | pa
  fgProduct      String  @db.VarChar(64) // <tem:Product>
  fgMajorClass   String  @db.VarChar(16)
  fgContractType String  @db.VarChar(16)
  fgPolicyType   String  @db.VarChar(16)
  isActive       Boolean @default(true)

  @@map("health_product_master")
}

// Cover / plan type offered for a product, with the allowed sum-insured band.
model HealthCoverMaster {
  id             Int     @id @default(autoincrement())
  productCode    String  @db.VarChar(32)
  code           String  @db.VarChar(32) // cover/plan type, e.g. Classic
  label          String  @db.VarChar(255)
  minSumInsured  Int?
  maxSumInsured  Int?
  sortOrder      Int     @default(0)
  isActive       Boolean @default(true)

  @@unique([productCode, code])
  @@index([productCode])
  @@map("health_cover_master")
}

model HealthOccupationMaster {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(16) // canonical = FG occupation code
  description String  @db.VarChar(191)
  fgCode      String  @db.VarChar(16)
  paRiskClass String? @db.VarChar(8) // PA occupation risk class
  isActive    Boolean @default(true)

  @@map("health_occupation_master")
}

model HealthRelationMaster {
  id       Int     @id @default(autoincrement())
  code     String  @unique @db.VarChar(24) // canonical relation, e.g. self
  label    String  @db.VarChar(64)
  fgCode   String  @db.VarChar(8)
  isActive Boolean @default(true)

  @@map("health_relation_master")
}

// ─── Masters ─────────────────────────────────────────────────────────────────

model RtoMaster {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(16)
  city        String   @db.VarChar(128)
  state       String   @db.VarChar(128)
  stateCode   String   @db.VarChar(8)
  // Motor zone (A/B for private car). No RTO→zone in the FG master, so it is
  // derived at seed time (metro cities → A, else B).
  zone        String?  @db.VarChar(4)
  isActive    Boolean  @default(true)

  providerCodes ProviderRtoCode[]

  @@index([state])
  @@map("rto_master")
}

model MmvMaster {
  id          Int      @id @default(autoincrement())
  makeId      String   @db.VarChar(64)
  makeName    String   @db.VarChar(128)
  // For FG, modelId holds the PASIA_CODE (its ModelCode, e.g. "HO0176").
  modelId     String   @db.VarChar(32)
  modelName   String   @db.VarChar(191)
  variantId   String?  @db.VarChar(32)
  variantName String?  @db.VarChar(191)
  fuelType    String   @db.VarChar(32)
  engineCC    Int?
  category    String   @db.VarChar(32) // fourWheeler | twoWheeler | commercial
  // Enrichment used to build the FG quote payload (esp. commercial).
  bodyType         String? @db.VarChar(64)
  gvw              Int?
  seatingCapacity  Int?
  carryingCapacity Int?
  vehicleType      String? @db.VarChar(191) // FG VEHICLE_TYPE class, e.g. "PV-Private Car"
  isActive    Boolean  @default(true)

  providerCodes ProviderMmvCode[]

  @@unique([makeId, modelId, variantId, fuelType])
  @@index([makeName])
  @@index([modelName])
  @@index([category])
  @@map("mmv_master")
}

model InsurerMaster {
  id           Int      @id @default(autoincrement())
  code         String   @unique @db.VarChar(32)
  name         String   @db.VarChar(255)
  shortName    String?  @db.VarChar(64)
  logoUrl      String?  @db.VarChar(512)
  isActive     Boolean  @default(true)

  providerCodes ProviderInsurerCode[]

  @@map("insurer_master")
}

// Provider-specific add-on catalog (FG: from the "Add On Covers" master sheet).
// Each row is a selectable cover/bundle the provider offers for a vehicle class.
model MotorAddon {
  id              Int     @id @default(autoincrement())
  providerSlug    String  @db.VarChar(64)
  category        String  @db.VarChar(32)  // fourWheeler | commercial
  fuelClass       String  @db.VarChar(16) @default("standard") // "electric" for the EV section
  code            String  @db.VarChar(16)  // FG CoverCode, e.g. ZCETR
  label           String  @db.VarChar(255)
  maxAgeYears     Float?
  requiresZeroDep Boolean @default(false)
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)

  @@unique([providerSlug, category, fuelClass, code])
  @@index([providerSlug, category])
  @@map("motor_addons")
}

model PincodeMaster {
  id      Int    @id @default(autoincrement())
  pincode String @db.VarChar(8)
  area    String @db.VarChar(191)
  city    String @db.VarChar(128)
  state   String @db.VarChar(128)

  @@index([pincode])
  @@map("pincode_master")
}

model OccupationMaster {
  id          Int    @id @default(autoincrement())
  code        String @unique @db.VarChar(16)
  description String @db.VarChar(191)

  @@map("occupation_master")
}

// ─── Provider Code Mappings ──────────────────────────────────────────────────

model ProviderRtoCode {
  id           Int       @id @default(autoincrement())
  providerSlug String    @db.VarChar(64)
  rtoId        Int
  rto          RtoMaster @relation(fields: [rtoId], references: [id])
  providerCode String    @db.VarChar(64)

  @@unique([providerSlug, rtoId])
  @@map("provider_rto_codes")
}

model ProviderMmvCode {
  id           Int       @id @default(autoincrement())
  providerSlug String    @db.VarChar(64)
  mmvId        Int
  mmv          MmvMaster @relation(fields: [mmvId], references: [id])
  providerMakeCode    String?  @db.VarChar(64)
  providerModelCode   String?  @db.VarChar(64)
  providerVariantCode String?  @db.VarChar(64)

  @@unique([providerSlug, mmvId])
  @@map("provider_mmv_codes")
}

model ProviderInsurerCode {
  id           Int           @id @default(autoincrement())
  providerSlug String        @db.VarChar(64)
  insurerId    Int
  insurer      InsurerMaster @relation(fields: [insurerId], references: [id])
  providerCode String        @db.VarChar(64)

  @@unique([providerSlug, insurerId])
  @@map("provider_insurer_codes")
}
