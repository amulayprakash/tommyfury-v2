# Copy to .env.development / .env.production and fill in per environment.

# Existing live Laravel API (auth, customers, cases, Zuno motor quotes, payments)
VITE_LEGACY_API_URL=https://insuranceapp.tommyandfurry.com/api

# New tf-api vendor quote service
VITE_VENDOR_API_URL=http://localhost:4000/api/v1

# Idle session timeout in minutes (warning shows 2 minutes before expiry)
VITE_IDLE_TIMEOUT_MIN=30
